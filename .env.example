# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
APP_URL=http://localhost:3000
INTERNAL_BASE_URL=http://localhost:3001
COOKIE_DOMAIN=localhost

# ─── Data / Storage ──────────────────────────────────────────────────────────
DATA_DIR=./data
DB_FILE=./data/users.db
MEDIA_DIR=./data/media
GENERATED_DIR=./data/generated
INTAKE_MEDIA_DIR=./data/intake

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ─── Stripe — Normal pricing ($249 / $495 / $749) ────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Current plan price IDs
STRIPE_BASE_PRICE_ID=price_...
STRIPE_DELUXE_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Legacy price IDs (grandfathered — do not remove)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_OPERATOR=price_...

# ─── Stripe — High-ticket test pricing ($495 / $995 / $1,500) ────────────────
STRIPE_TEST_BASE_PRICE_ID=price_1Tg5MPPT5b2dVWTGC9d0HbkO
STRIPE_TEST_DELUXE_PRICE_ID=price_1Tg5MqPT5b2dVWTGuc2kWk09
STRIPE_TEST_PREMIUM_PRICE_ID=price_1Tg5NDPT5b2dVWTGvTtDGVju

# ─── Facebook / Meta ─────────────────────────────────────────────────────────
FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...
FACEBOOK_LOGIN_CONFIG_ID=...
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback
META_API_VERSION=v19.0

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=noreply@yourdomain.com

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_BYPASS_USERNAME=admin
ADMIN_BYPASS_PASSWORD=...
SM_INTERNAL_API_KEY=...
SMARTEMARK_DEBUG_KEY=...

# ─── Optimizer / AI ──────────────────────────────────────────────────────────
OPTIMIZER_AUTORUN_ENABLED=true
OPTIMIZER_AUTORUN_INTERVAL_MINUTES=60
OPTIMIZER_AUTORUN_LIMIT=5
OPTIMIZER_AUTORUN_ACCOUNT_ID=
OPTIMIZER_AUTORUN_OWNER_KEY=
OPTIMIZER_BRAIN_MODEL=gpt-4o
OPTIMIZER_USE_AI_BRAIN=true
OPTIMIZER_MIN_HOURS_BETWEEN_RUNS=6
OPTIMIZER_CONVERSION_TRACKING_ENABLED=false
SMARTEMARK_MIN_CREATIVE_TEST_HOURS=24
SMARTEMARK_AI_OPERATOR_DRY_RUN=false
ALLOW_NO_SPEND=false
